# Copy this file to .env and fill in your keys.
# .env should be gitignored.

# Tavily API key — required for search_internet tool
# Get one free at https://tavily.com/
TAVILY_API_KEY=your-tavily-key-here

# arXiv requires NO API key. The arxiv Python package talks directly
# to the arXiv API. No env var needed.
